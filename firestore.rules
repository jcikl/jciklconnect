rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      return exists(/databases/$(database)/documents/members/$(request.auth.uid)) ? 
             get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role : 
             null;
    }
    
    function isMember() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
             getUserRole() != null &&
             getUserRole() in ['GUEST', 'MEMBER', 'BOARD', 'ADMIN', 'SUPER_ADMIN'];
    }

    // isActiveMember: MEMBER and above — excludes GUEST (self-registered, not yet vetted)
    function isActiveMember() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
             getUserRole() != null &&
             getUserRole() in ['MEMBER', 'BOARD', 'ADMIN', 'SUPER_ADMIN'];
    }
    
    function memberData() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data;
    }

    // Synced from boardMembers when assigned to the current calendar-year board
    function isCurrentBoardMember() {
      return exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
             memberData().get('isCurrentBoardMember', false) == true;
    }

    // isBoard() intentionally includes ADMIN as a superset of BOARD for Firestore collection access.
    // Note: usePermissions.ts board-elevation block explicitly excludes ADMIN (ADMIN gets permissions from
    // ROLE_PERMISSIONS[ADMIN] directly, not from the board elevation path). These are intentionally different.
    // Honorary and Senator membershipType members are assigned role=BOARD via roleForMembershipType().
    // They therefore pass isBoard() checks and can access board-level collections as designed.
    function isBoard() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
             (
               (getUserRole() != null && getUserRole() in ['BOARD', 'ADMIN']) ||
               isCurrentBoardMember()
             );
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
             getUserRole() != null &&
             getUserRole() in ['ADMIN', 'SUPER_ADMIN'];
    }

    function isDeveloper() {
      return isAuthenticated() && (
        request.auth.token.get('developer', false) == true ||
        request.auth.token.get('isDeveloper', false) == true ||
        (
          exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
          memberData().get('isDeveloper', false) == true
        ) ||
        getUserRole() == 'SUPER_ADMIN'
      );
    }
    
    // Roles that can read members at org/LO level (board members and admins)
    function canReadOrgMembers() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
             (
               (getUserRole() != null &&
                getUserRole() in ['ADMIN', 'BOARD']) ||
               isCurrentBoardMember()
             );
    }

    // Roles that can edit members
    function canEditMembers() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
             (
               (getUserRole() != null &&
                getUserRole() in ['ADMIN', 'BOARD']) ||
               isCurrentBoardMember()
             );
    }
    
    function getMyLoId() {
      return exists(/databases/$(database)/documents/members/$(request.auth.uid)) ? 
             get(/databases/$(database)/documents/members/$(request.auth.uid)).data.get('loId', null) : null;
    }
    
    // Same LO or legacy doc (no loId) for org-level readers
    function resourceInMyLo(resourceData) {
      let myLo = getMyLoId();
      return myLo != null && (resourceData.get('loId', null) == myLo || resourceData.get('loId', null) == null);
    }
    
    // Users collection (FCM tokens)
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Members collection: 组织财政/活动财政/会员 boundary; multi-LO: read by same loId or self.
    match /members/{memberId} {
      // 1. Basic Read Access (Get and List)
      // Public business profiles are served from the businessDirectory subcollection — not here.
      allow get, read: if isAuthenticated() && (
        request.auth.uid == memberId ||
        (resource != null && resource.data.get('email', '') == request.auth.token.get('email', '')) ||
        isActiveMember() ||
        canReadOrgMembers()
      );

      // Allow listing for email search during linking only (business directory uses businessDirectory subcollection)
      // SEC: exclude GUEST — isMember() includes GUEST, which would let any self-registered
      // GUEST dump the full member roster (NRIC, DOB, phone). Use isActiveMember() instead.
      // TODO: loId filter — resource.data is null in list queries so per-doc loId check is not viable here; enforce at service layer
      allow list: if isAuthenticated() && (
        isActiveMember() ||
        canReadOrgMembers() ||
        (request.query.filters.get('email', []) == [request.auth.token.get('email', '')]) ||
        (request.query.filters.email == [request.auth.token.get('email', '')])
      );

      // 2. Create/Update/Delete Access
      allow create: if isAuthenticated() &&
                       (request.auth.uid == memberId || isBoard()) &&
                       request.resource.data.name is string &&
                       request.resource.data.email is string &&
                       request.resource.data.role is string &&
                       (isBoard() || request.resource.data.get('role', 'GUEST') == 'GUEST');

      // Self-write: members may update any profile field EXCEPT the locked list below.
      // GUEST may also set nationality/dob/idNumber; once promoted to MEMBER+ those three are locked.
      // BOARD+ edits: senatorshipId is immutable once board-validated; only Admin can override (E2 fix).
      allow update: if isAuthenticated() && (
        (request.auth.uid == memberId &&
         // E8 fix: require required fields are always present so self-write cannot delete name/email
         request.resource.data.keys().hasAll(['name', 'email']) &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny([
           'role', 'loId', 'membership', 'membershipType',
           'senatorCertified', 'senatorshipBoardValidated', 'senatorshipId',
           'senatorshipValidatedAt', 'senatorshipValidatedBy',
           'jciCareer', 'menteeIds', 'mentorId',
           'deletedAt', 'deletedBy', 'createdAt', 'createdBy',
           'attendanceCheckins', 'attendanceMonths', 'attendanceYear',
           'leaderboardScore', 'points',
           'churnRisk', 'tier', 'birthdayMMDD', 'isDeveloper',
           'isCurrentBoardMember', 'currentBoardPosition'
         ]) &&
         (resource.data.get('role', 'GUEST') == 'GUEST' ||
          (request.resource.data.get('general', {}).get('nationality', null) == resource.data.get('general', {}).get('nationality', null) &&
           request.resource.data.get('general', {}).get('dob', null)         == resource.data.get('general', {}).get('dob', null) &&
           request.resource.data.get('general', {}).get('idNumber', null)    == resource.data.get('general', {}).get('idNumber', null) &&
           request.resource.data.get('general', {}).get('idType', null)      == resource.data.get('general', {}).get('idType', null)))
        ) ||
        (canEditMembers() && (resource == null || resourceInMyLo(resource.data)) &&
         // BOARD members cannot elevate anyone to ADMIN / SUPER_ADMIN (E13 fix)
         (isAdmin() ||
          !(request.resource.data.get('role', resource.data.get('role', '')) in ['ADMIN', 'SUPER_ADMIN'])) &&
         (isAdmin() ||
          !resource.data.get('senatorshipBoardValidated', false) ||
          request.resource.data.get('senatorshipId', resource.data.get('senatorshipId', null))
            == resource.data.get('senatorshipId', null))
        )
      );

      // Only admins may delete; self-delete removed to prevent orphan data (E07)
      allow delete: if isAdmin() && resourceInMyLo(resource.data);
    }
    
    // Communication/Posts collection
    match /communication/{postId} {
      // Allow read: authenticated users (including those without member doc yet)
      allow read: if isAuthenticated();
      
      // Allow create: active members only (MEMBER+); GUEST excluded; require author attribution
      allow create: if isActiveMember() &&
                       request.resource.data.keys().hasAll(['author', 'content', 'createdAt']) &&
                       request.resource.data.author.id == request.auth.uid;
      
      // Allow update: post author or board/admin/super_admin (if member doc exists)
      allow update: if isAuthenticated() &&
                       (resource.data.author.id == request.auth.uid ||
                        (exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN', 'SUPER_ADMIN']));

      // Allow delete: post author or board/admin/super_admin (if member doc exists)
      allow delete: if isAuthenticated() &&
                       (resource.data.author.id == request.auth.uid ||
                        (exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN', 'SUPER_ADMIN']));
    }
    
    // Events collection
    match /events/{eventId} {
      // FIX 2: split read so public events page returns results.
      // resource.data is null during list queries, so any resource.data condition on allow read
      // would silently block all list results. allow list: if true lets unauthenticated visitors
      // see the public events page; the service layer where() clause filters by status.
      allow get: if isAuthenticated();
      allow list: if true;
      // FIX 1: restrict writes to Board+; members may update only their own attendance fields
      allow create, delete: if isBoard() || isAdmin();
      allow update: if isBoard() || isAdmin() ||
                       (isMember() &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['attendees', 'registeredMembers', 'updatedAt']));
    }
    
    // Projects collection
    match /projects/{projectId} {
      // Public events page uses getDocs(query(projects, where('status','==','Active'))).
      // Firestore list rules can't filter by query params, so allow list: if true lets the
      // unauthenticated guest events page work; service layer filters status in code.
      allow get: if isAuthenticated() || resource.data.status == 'Active';
      allow list: if true;
      // FIX 1: restrict writes to Board+; members may update only their own attendance/registration fields
      allow create, delete: if isBoard() || isAdmin();
      allow update: if isBoard() || isAdmin() ||
                       (isMember() &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['attendees', 'registeredMembers', 'updatedAt']));
    }

    // Flagship Projects collection
    match /flagship_projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isBoard() || isAdmin();
    }

    // Project tasks collection (Kanban, Gantt)
    match /tasks/{taskId} {
      // FIX 12: any authenticated user (including GUEST) was previously able to create and delete tasks
      allow read: if isMember();
      allow create: if isMember() &&
                       request.resource.data.keys().hasAll(['title', 'assignedTo', 'projectId', 'createdAt']);
      allow update: if isBoard() || isAdmin() ||
                       (isMember() && resource.data.assignedTo == request.auth.uid);
      allow delete: if isBoard() || isAdmin();
    }
    
    // Treasurer: current board member whose position title contains "Treasurer", plus Admin override
    function isTreasurer() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
             (isAdmin() ||
              (isCurrentBoardMember() &&
               memberData().get('currentBoardPosition', '').matches('.*[Tt]reasurer.*')));
    }

    // Finance access: current-calendar-year board members and admins
    function canAccessFinance() {
      return isBoard();
    }

    // Deletion is destructive and irreversible — reserved for board members and admins.
    function canDeleteFinance() {
      return isBoard();
    }

    // Transactions: board / finance roles; multi-LO scoped by loId unless isAdmin/Board()
    match /transactions/{transactionId} {
      // TX-R1: split read into get (resource.data valid) and list (resource.data is null — no loId check)
      allow get: if isAuthenticated() &&
        (isAdmin() ||
         isBoard() ||
         (canAccessFinance() && (resource == null || resource.data.get('loId', null) == null || resource.data.get('loId', null) == getMyLoId())));
      allow list: if isAuthenticated() && (isAdmin() || isBoard());
      // E8 fix: on CREATE resource is null; must use request.resource.data not resource.data
      allow create: if canAccessFinance() &&
        (request.resource.data.get('status', '') != 'Reconciled' &&
         request.resource.data.get('status', '') != 'Partially Reconciled' &&
         request.resource.data.get('status', '') != 'Voided');
      // TX-R2: finance staff limited to business fields; Admin unrestricted (TX-A: added missing writable fields)
      // C1: isAdmin() bypass before Reconciled check so void/unmatch/deleteReconciliation always work
      allow update: if isAdmin() ||
        (canAccessFinance() &&
        (resource == null ||
          (resource.data.get('status', '') != 'Reconciled' &&
           resource.data.get('status', '') != 'Partially Reconciled' &&
           resource.data.get('status', '') != 'Voided')) &&
         // E1 fix: added 'memberId', 'loId', 'transactionType', 'year' to Board-level hasOnly
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'status', 'reconciliationId', 'reconciledAt', 'reconciledBy',
           'prevStatus', 'paidAt', 'paidBy', 'updatedAt', 'updatedBy', 'notes', 'category',
           'isSplit', 'splitIds', 'originalCategory', 'projectId', 'purpose', 'projectTransactionIds',
           'description', 'amount', 'type', 'date', 'reference', 'bankAccountId', 'attachments',
           'paymentRequestId', 'inventoryLinkId', 'inventoryVariant', 'inventoryQuantity', 'tags',
           'matchStatus', 'matchedBankTxIds',
           'memberId', 'loId', 'transactionType', 'year'
         ]));
      allow delete: if isAdmin() || (canDeleteFinance() &&
        resource.data.get('status', '') != 'Reconciled' &&
        resource.data.get('status', '') != 'Partially Reconciled' &&
        resource.data.get('status', '') != 'Cleared' &&
        resource.data.get('status', '') != 'Voided');
    }

    // Transaction Splits: same rules as transactions; update/delete blocked on Reconciled parent
    match /transactionSplits/{splitId} {
      // E1 fix (P0): TransactionSplit docs have no loId field so the old loId check was always true,
      // exposing cross-LO splits to any finance user. Replaced with isBoard()/isAdmin() only.
      // Cross-LO isolation at split level requires a data migration to add loId — out of scope here.
      allow read: if isAuthenticated() && (isAdmin() || isBoard());
      // T7: block adding splits to already-reconciled parent transactions
      allow create: if canAccessFinance() &&
        get(/databases/$(database)/documents/transactions/$(request.resource.data.get('parentTransactionId', ''))).data.get('status', '') != 'Reconciled';
      allow update: if canAccessFinance() &&
        (!exists(/databases/$(database)/documents/transactions/$(resource.data.parentTransactionId)) ||
         (get(/databases/$(database)/documents/transactions/$(resource.data.parentTransactionId)).data.get('status', '') != 'Reconciled' &&
          get(/databases/$(database)/documents/transactions/$(resource.data.parentTransactionId)).data.get('status', '') != 'Partially Reconciled' &&
          get(/databases/$(database)/documents/transactions/$(resource.data.parentTransactionId)).data.get('status', '') != 'Voided')) &&
        (isAdmin() ||
         // E7 fix: removed 'type' from non-admin hasOnly — users must not change split type directly
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'description', 'amount', 'category', 'projectId', 'year', 'memberId',
           'purpose', 'paymentRequestId', 'notes', 'updatedAt', 'updatedBy',
           'status', 'reconciledAt', 'reconciledBy', 'projectTransactionId', 'projectTransactionIds',
           'inventoryLinkId', 'inventoryVariant', 'inventoryQuantity'
         ]));
      allow delete: if canDeleteFinance() &&
        (!exists(/databases/$(database)/documents/transactions/$(resource.data.parentTransactionId)) ||
         (get(/databases/$(database)/documents/transactions/$(resource.data.parentTransactionId)).data.get('status', '') != 'Reconciled' &&
          get(/databases/$(database)/documents/transactions/$(resource.data.parentTransactionId)).data.get('status', '') != 'Partially Reconciled' &&
          get(/databases/$(database)/documents/transactions/$(resource.data.parentTransactionId)).data.get('status', '') != 'Voided'));
    }

    // Project Transactions (Story 4.1): Project-specific financials.
    // These carry the same reconciliation reverse-index (matchedBankAmount etc.) as
    // `transactions`, so they get the same finance-role gate — not just isAuthenticated().
    match /projectTrx/{transactionId} {
      // PT-1: INACTIVE members excluded; finance/board-only gate mirrors transactions collection
      // PT-R1: split get/list so loId scoping works in list queries (resource.data is null in list)
      allow get: if isAuthenticated() && (isAdmin() || isBoard() || canAccessFinance());
      // E7 fix: add isAdmin() guard so admin batch scans are not blocked by resource.data-null list rules
      allow list: if isAuthenticated() && (isAdmin() || isBoard() ||
        (canAccessFinance() && getMyLoId() != null));
      // E1 fix: add hasOnly to prevent arbitrary fields being written on create
      allow create: if canAccessFinance() &&
        request.resource.data.keys().hasAll(['projectId', 'amount', 'type']) &&
        request.resource.data.keys().hasOnly([
          'projectId', 'amount', 'type', 'description', 'date', 'createdBy', 'createdAt',
          'bankAccountId', 'loId', 'currency', 'status'
        ]);
      // PT-update/delete: block modifications to already-reconciled project transactions; PT-U2: add hasOnly
      allow update: if canAccessFinance() &&
        resource.data.get('status', '') != 'Reconciled' &&
        (isAdmin() ||
         // E2 fix: removed 'status' from non-admin hasOnly — regular finance users must not set status=Reconciled
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'description', 'amount', 'type', 'date', 'category', 'notes',
           'reference', 'attachments', 'updatedAt', 'updatedBy', 'approvedBy', 'approvedAt',
           'rejectedBy', 'rejectedAt', 'rejectionReason'
         ]));
      allow delete: if canDeleteFinance() &&
        resource.data.get('status', '') != 'Reconciled';
    }
    

    // Bank Accounts: Board+ can view; only Honorary Treasurer (or Admin) can create/update/delete.
    match /bankAccounts/{accountId} {
      allow get: if canAccessFinance() &&
        (isAdmin() ||
         resource.data.get('loId', null) == null ||
         resource.data.get('loId', null) == getMyLoId());
      allow list: if isAdmin() || canAccessFinance();
      allow create, update, delete: if isTreasurer();
    }
    
    // Payment Requests (Story 2.1): applicantId, amount, purpose, activityRef, referenceNumber, status, loId, 审计
    function paymentRequestInMyScope() {
      let myLo = getMyLoId();
      let docLo = resource.data.get('loId', null);
      // 财政可见：同 LO，或文档无 loId（兼容旧数据），或本人无 loId 视为单 LO 可见全部
      return docLo == myLo || docLo == null || myLo == null;
    }
    match /paymentRequests/{requestId} {
      allow get: if isAuthenticated() &&
        (isAdmin() ||
         resource.data.get('applicantId', null) == request.auth.uid ||
         (canAccessFinance() && paymentRequestInMyScope()));
      allow list: if isAuthenticated() &&
        (isAdmin() || canAccessFinance());
      allow create: if isAuthenticated() &&
        request.resource.data.get('applicantId', null) == request.auth.uid &&
        request.resource.data.get('loId', null) is string &&
        request.resource.data.get('referenceNumber', null) is string &&
        request.resource.data.get('status', null) in ['draft', 'submitted'];
      allow update: if isAuthenticated() &&
        (isAdmin() ||
         resource.data.get('applicantId', null) == request.auth.uid && resource.data.get('status', null) == 'draft' &&
           // E4 fix: added 'purpose' — service writes purpose alongside title/description on draft edit
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'purpose', 'amount', 'totalAmount', 'activityRef', 'items', 'attachments', 'category', 'updatedAt', 'updatedBy', 'status']) &&
           request.resource.data.get('status', null) in ['draft', 'submitted'] ||
         resource.data.get('applicantId', null) == request.auth.uid && resource.data.get('status', null) in ['submitted', 'approved'] && request.resource.data.get('status', null) == 'cancelled' &&
           // E2 fix: added 'expenseTxFailed' — service writes this flag when transaction delete fails on cancel
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'updatedBy', 'expenseTxFailed']) ||
         resource.data.get('applicantId', null) == request.auth.uid && resource.data.get('status', null) == 'rejected' && request.resource.data.get('status', null) == 'submitted' &&
           // E1 fix: added rejectionReason/reviewedBy/reviewedAt — service clears these on resubmit
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'updatedBy', 'rejectionReason', 'reviewedBy', 'reviewedAt']) ||
         canAccessFinance() && paymentRequestInMyScope() &&
           // Fix 9 (P2): added 'projectBudgetSyncFailed' and 'expenseTxFailed' so finance staff
           // can write these flag fields without needing admin rights.
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reviewedBy', 'reviewedAt', 'updatedAt', 'updatedBy', 'remark', 'rejectionReason', 'paidAt', 'projectBudgetSyncFailed', 'expenseTxFailed']));
      allow delete: if isAuthenticated() && (
        (resource.data.get('applicantId', null) == request.auth.uid && resource.data.get('status', null) == 'draft') ||
        isAdmin() || isDeveloper());
    }

    // Story 9.1: 非会员留资
    // FIX 15: allow create: if true had no field validation — bots/spammers could write arbitrary content
    match /nonMemberLeads/{leadId} {
      allow read: if isAuthenticated() && canReadOrgMembers();
      // P0 Fix: removed isAuthenticated() requirement — public form submissions come from unauthenticated users.
      // Field validation prevents arbitrary writes: required fields enforced via hasAll, allowlist via hasOnly.
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'source', 'createdAt']) &&
                      request.resource.data.keys().hasOnly(['name', 'email', 'phone', 'source', 'message', 'createdAt', 'eventId', 'loId']);
      allow update, delete: if isAuthenticated() && canReadOrgMembers();
    }

    // Story 8.1: 报名/缴费/签到统一名单
    // Fields a member may self-service on their own registration (non-financial).
    // Anything payment/status related must go through canReadOrgMembers() (board/finance/committee).
    // E-4: protect audit fields (cancelledBy*, registeredBy*, memberName) from self-write
    function eventRegSelfUpdateOnlyTouchesOwnFields() {
      let unchanged = ['status', 'paidAt', 'checkedInAt', 'paymentMethod', 'financeTransactionId',
        'matchedBankTxId', 'toyyibBillCode', 'toyyibPaymentUrl', 'toyyibPaymentStatus', 'billExternalReferenceNo',
        'cancelledAt', 'cancelledBy', 'cancelledByName', 'cancelledByRole',
        'registeredBy', 'registeredByName', 'memberName',
        'eventId', 'memberId', 'loId', 'createdAt', 'updatedAt'];
      return unchanged.toSet().difference(request.resource.data.diff(resource.data).affectedKeys()).size() == unchanged.size();
    }
    match /eventRegistrations/{regId} {
      // ER-R1: split get/list — resource.data is null in list queries; members can only self-read via get
      allow get: if isAuthenticated() &&
        (isAdmin() || resource.data.get('memberId', null) == request.auth.uid || canReadOrgMembers());
      // E1 fix: removed isMember() — any member could list ALL registrations across all events.
      // Members may only self-read via allow get above; listing requires Board+.
      allow list: if isAuthenticated() && (isAdmin() || canReadOrgMembers());
      allow create: if isAuthenticated() &&
        request.resource.data.get('memberId', null) is string &&
        request.resource.data.get('eventId', null) is string &&
        (request.resource.data.get('memberId', null) == request.auth.uid || canReadOrgMembers());
      // ER-U4: Board update add hasOnly — prevent overwriting points/attendedAt/memberId from SDK
      allow update: if isAuthenticated() &&
        ((canReadOrgMembers() && (isAdmin() ||
           request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'status', 'paidAt', 'checkedInAt', 'paymentMethod', 'financeTransactionId',
             'matchedBankTxId', 'toyyibBillCode', 'toyyibPaymentUrl', 'toyyibPaymentStatus',
             'billExternalReferenceNo', 'cancelledAt', 'cancelledBy', 'cancelledByName', 'cancelledByRole',
             'registeredBy', 'registeredByName', 'memberName', 'notes', 'updatedAt', 'updatedBy',
             'points', 'attendedAt', 'attended'
           ]))) ||
         (resource.data.get('memberId', null) == request.auth.uid && eventRegSelfUpdateOnlyTouchesOwnFields()));
      // E-1: members may NOT hard-delete their own registration (bypasses finance tx cleanup); only board+ can delete
      allow delete: if isAuthenticated() && canReadOrgMembers();
    }
    
    // Points collection
    match /points/{pointId} {
      allow read: if isAuthenticated();
      // FIX 3: any authenticated user was able to create point records for any member (self-score fraud).
      // Admin can award any member; members may only self-submit with required fields present.
      allow create: if isAdmin() ||
                       (isMember() &&
                        request.resource.data.memberId == request.auth.uid &&
                        request.resource.data.keys().hasAll(['memberId', 'points', 'type', 'createdAt']));
      allow update, delete: if isAdmin() || isBoard();
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // E1 fix (P0): allow read was used for both get and list, but resource.data is null in list queries,
      // so the memberId == uid check always failed — members could never see their own notifications.
      // Fix: split into get (resource.data valid) and list (service-layer where clause enforces ownership).
      allow get: if isAuthenticated() &&
                    (resource.data.memberId == request.auth.uid ||
                     (exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                      get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN']));
      // INTENTIONAL DESIGN: resource.data is unavailable in list queries, so ownership cannot be
      // enforced at the Firestore-rules layer for list. The service layer MUST always include
      // where('memberId', '==', uid) in every list query — this prevents unfiltered reads from
      // returning useful data even if rules pass. A compound index on (memberId ASC, timestamp DESC)
      // must exist so Firestore rejects queries that omit the memberId equality filter.
      allow list: if isAuthenticated() &&
                     (isMember() ||
                      (exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                       get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN']));
      
      // PR-C: MEMBER cancel/submit notifications need create rights; N-8: require all fields present
      // isBoard() for general notifications; isMember() for specific self-service action types only
      allow create: if isAuthenticated() && (isBoard() ||
        (isMember() &&
         request.resource.data.keys().hasAll(['memberId','title','message','type','read']) &&
         request.resource.data.get('type', '') in [
           'payment_request_cancelled', 'payment_request_submitted',
           'payment_request_updated', 'event_registration_cancelled',
           'info'
         ]));

      // Users can mark their own notifications as read; board/admin can update any field
      allow update: if isAuthenticated() &&
                       (isAdmin() ||
                        (exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN']) ||
                        (resource.data.memberId == request.auth.uid &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt'])));
      
      // N-7: allow members to delete their own notifications for inbox cleanup
      allow delete: if isAuthenticated() &&
                       (resource.data.memberId == request.auth.uid ||
                        (exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN']));
    }

    // Documents collection
    // FIX 7: restrict writes to Board/Admin — any member was previously able to create/update/delete governance docs
    match /documents/{documentId} {
      allow read: if isAuthenticated();
      allow create, update: if isBoard() || isAdmin();
      allow delete: if isAdmin();
    }

    // Document Versions collection
    // FIX 6: was completely missing (default deny) — version history operations always silently failed
    match /documentVersions/{versionId} {
      allow read: if isAuthenticated();
      allow create: if isBoard() || isAdmin();
      allow update, delete: if isAdmin();
    }
    
    // Surveys collection
    match /surveys/{surveyId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && 
                                       exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                                       get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN'];
    }
    
    // Survey Responses collection
    // FIX 5: allow read used resource.data.memberId which is null in list queries — members could never list their own responses
    match /surveyResponses/{responseId} {
      // resource.data valid for get; service-layer where(memberId == uid) handles list ownership
      allow get: if isAuthenticated() &&
                    (resource.data.memberId == request.auth.uid || isBoard() || isAdmin());
      allow list: if isActiveMember();
      allow create: if isAuthenticated() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isBoard() || isAdmin();
    }

    // Elections collection (board elections with sub-collection ballots)
    // FIX 1: collection had no match block — all access silently denied by catch-all
    match /elections/{electionId} {
      allow read: if isMember() || isBoard() || isAdmin();
      allow create, update: if isBoard() || isAdmin();
      allow delete: if isAdmin();

      // Ballots sub-collection — deterministic docId (uid_electionId) prevents double voting
      match /ballots/{ballotId} {
        allow read: if isBoard() || isAdmin() || request.auth.uid == resource.data.voterId;
        allow create: if isMember() && ballotId == request.auth.uid + '_' + electionId;
        allow update, delete: if isAdmin();
      }
    }

    // Votes collection (standalone voting records across all elections)
    match /votes/{voteId} {
      // FIX 4: split read — resource.data is null in list queries; protect ballot privacy
      allow get: if isAdmin() || (isMember() && resource.data.voterId == request.auth.uid);
      allow list: if isAdmin();
      // P1 Fix: require deterministic document ID = uid + '_' + electionId to prevent duplicate votes.
      // The service must use this compound key when writing vote documents.
      allow create: if isMember() &&
                      request.resource.data.voterId == request.auth.uid &&
                      voteId == request.auth.uid + '_' + request.resource.data.electionId;
      allow update, delete: if false;  // votes are immutable once cast

      // voteCasts is a subcollection of /votes/{voteId} — written by votesService.ts
      // NOTE: VotesService has no UI entry point as of 2026-07 — this rule is here for when the feature is wired up
      match /voteCasts/{castId} {
        // FIX 4: cast-level ballot detail is admin-only to prevent voter identification
        allow read: if isAdmin();
        allow create: if isMember() && request.resource.data.voterId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    
    // /proposals collection — no service implementation as of 2026-07. Rule kept as placeholder.
    // FIX 9: require MEMBER+ to read/create proposals — GUEST excluded
    match /proposals/{proposalId} {
      allow read: if isActiveMember();
      allow create: if isActiveMember();
      allow update, delete: if isAuthenticated() &&
                               exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                               get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN'];
    }
    
    // Workflows collection
    match /workflows/{workflowId} {
      // FIX 11: list rule must not use resource.data (null in list queries).
      // Restricted to Board+; delete to Admin only — workflow deletion can silence automation.
      allow read: if isBoard() || isAdmin();
      allow create, update: if isBoard() || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Workflow Executions collection
    // FIX 8: was open to all authenticated — any member could forge execution records; reads leak automation internals
    match /workflow_executions/{executionId} {
      allow read: if isBoard() || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Automation Rules collection
    match /automationRules/{ruleId} {
      allow read: if isAuthenticated();
      // FIX 9: delete restricted to Admin only — a BOARD member deleting a rule can silently
      // disable automation (e.g. membership renewal reminders) with no audit trail.
      allow create, update: if isBoard() || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Inventory collection
    // I-8: update hasOnly — lock system fields (createdAt, lastTransactionId) from direct overwrite
    // C12: restrict read to isMember() to exclude GUEST/INACTIVE
    match /inventory/{itemId} {
      allow read: if isAuthenticated() && isMember();
      allow create, delete: if isAuthenticated() && (isAdmin() || isBoard());
      allow update: if isAuthenticated() && (isAdmin() || isBoard()) &&
        (isAdmin() ||
         // E4 fix: removed 'lastTransactionId' and 'lastTransactionDate' — these are system-managed
         // link fields written by the inventory transaction service, not by Board users directly.
         request.resource.data.diff(resource.data).affectedKeys().hasOnly([
           'name', 'description', 'quantity', 'status', 'location', 'variants',
           'minQuantity', 'category', 'purchasePrice', 'depreciatedValue', 'notes',
           'lastCheckedAt', 'checkedOutTo', 'checkedOutDate', 'expectedReturnDate',
           'updatedAt', 'updatedBy', 'tags', 'serialNumber', 'condition',
           'returnedDate', 'lastSaleDate', 'purchaseDate', 'currentValue', 'lastDepreciationUpdate'
         ]));
    }

    // Stock Movements collection
    // I-4: restrict read to MEMBER+ (was isAuthenticated which includes GUEST)
    // FIX 21: removed allow update — stock movements are audit records and must be append-only;
    //         Board was able to overwrite movement records, corrupting the inventory audit trail
    match /stock_movements/{movementId} {
      allow read: if isAuthenticated() && isMember();
      allow create: if isMember() || isBoard() || isAdmin();
      // No allow update — stock movements are immutable audit records
      allow delete: if isAdmin();
    }
    
    // Hobby Clubs collection
    // FIX 12: any authenticated user (including GUEST) could create/update/delete any club
    match /hobbyClubs/{clubId} {
      allow read: if isAuthenticated();
      // P2 Fix: exclude GUEST role from creating clubs — only MEMBER and above.
      allow create: if (isMember() && getUserRole() != 'GUEST') || isBoard() || isAdmin();
      // Club lead can update descriptive fields only — leadId and memberIds are admin-managed
      allow update: if isBoard() || isAdmin() ||
                      (isMember() && resource.data.leadId == request.auth.uid
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['leadId', 'memberIds']));
      allow delete: if isAdmin();
    }
    
    // Business Profiles collection
    // FIX 20: allow update was checking request.resource.data.memberId (new data) — attacker sets memberId to self
    //         to claim any profile; must check resource.data.memberId (existing owner)
    match /businessProfiles/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.memberId == request.auth.uid;
      // Owner can update non-identity fields only — memberId must not change
      allow update: if isAdmin() || (isAuthenticated() && resource.data.memberId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['memberId']));
      allow delete: if isAdmin() || isBoard();
    }
    
    // Inquiries collection (Business Directory)
    // FIX 3: allow read used resource.data in list queries (always null) — members could never list their inquiries
    match /inquiries/{inquiryId} {
      allow get: if isAuthenticated() &&
                    (resource.data.senderId == request.auth.uid ||
                     resource.data.recipientId == request.auth.uid ||
                     isBoard() || isAdmin());
      allow list: if isBoard() || isAdmin();
      allow create: if isAuthenticated() &&
                       request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() &&
                       (resource.data.senderId == request.auth.uid ||
                        resource.data.recipientId == request.auth.uid ||
                        (exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN']));
      allow delete: if isAuthenticated() &&
                       exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                       get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN'];
    }

    // Badges collection
    match /badges/{badgeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard();
    }
    
    // Badge Awards collection
    match /badgeAwards/{awardId} {
      allow read: if isAuthenticated();
      allow create: if isBoard();
      allow update, delete: if isBoard();
    }
    
    // Achievements collection
    match /achievements/{achievementId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard();
    }
    
    // Achievement Awards collection
    match /achievementAwards/{awardId} {
      allow read: if isAuthenticated();
      allow create: if isBoard();
      allow update, delete: if isBoard();
    }
    
    // Advertisements collection
    // FIX 13: update click/impression tracking branch was missing isAuthenticated() — anonymous users could spam counters
    match /advertisements/{adId} {
      allow read: if true;
      allow create, delete: if isBoard();
      allow update: if isBoard() ||
        (isAuthenticated() &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['impressions', 'clicks', 'updatedAt']));
    }
    
    // Promotion Packages collection
    match /promotionPackages/{packageId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard();
    }

    // Probation to Full Member promotion workflow
    match /manualPromotionRequests/{requestId} {
      // FIX: allow the applicant to read their own promotion request
      allow read: if isBoard() || isAdmin() || request.auth.uid == resource.data.memberId;
      allow create, update, delete: if isBoard() || isAdmin() || isDeveloper();
    }

    match /promotionHistory/{historyId} {
      // FIX: allow the subject member to read their own promotion history
      // FIX 4: split read — resource.data is null in list queries so memberId check always failed for lists
      allow get: if isBoard() || isAdmin() || isDeveloper() || resource.data.memberId == request.auth.uid;
      allow list: if isBoard() || isAdmin() || isDeveloper();
      allow create, update, delete: if isBoard() || isAdmin() || isDeveloper();
    }
    
    // Activity Plans collection
    // FIX 4: any authenticated user (including GUEST) could create/update/delete activity plans
    match /activityPlans/{planId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard() || isAdmin();
    }
    
    // Templates collection
    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard();
    }
    
    // Member Benefits collection
    match /memberBenefits/{benefitId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard();
    }
    
    // Benefit Usage collection
    match /benefitUsage/{usageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.memberId == request.auth.uid &&
        request.resource.data.keys().hasOnly(['memberId', 'benefitId', 'usedAt', 'notes', 'createdAt', 'loId']);
      allow update, delete: if isAuthenticated() &&
                               exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                               get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN'];
    }
    
    // Conversations collection
    // FIX 2: allow read used resource.data.participants which is null in list queries — members could never list conversations
    match /conversations/{conversationId} {
      // resource.data.participants valid on get; list restricted to Board/Admin (members use real-time subscription)
      allow get: if isAuthenticated() && (isBoard() || isAdmin() ||
                    request.auth.uid in resource.data.participants);
      allow list: if isBoard() || isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isBoard() || isAdmin();
    }

    // Messages collection (top-level; conversationId stored on each doc)
    // FIX 3: was open to all authenticated — any member could read messages from any conversation
    match /messages/{messageId} {
      // get: check parent conversation participants via cross-doc read
      allow get: if isBoard() || isAdmin() ||
                   (isAuthenticated() &&
                    request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants);
      // list: Board/Admin only; members get messages via real-time subscription scoped to their conversations
      allow list: if isBoard() || isAdmin();
      allow create: if isAuthenticated() &&
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversationId)).data.participants;
      allow update, delete: if isAdmin();
    }
    
    // Webhooks collection
    match /webhooks/{webhookId} {
      allow read, create, update, delete: if isAuthenticated() && 
                                             exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                                             get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN'];
    }
    
    // Webhook Logs collection
    // FIX 18: allow create was open to any authenticated user — members could inject fake webhook logs
    match /webhook_logs/{logId} {
      allow read: if isBoard() || isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }
    
    // Reconciliations collection
    // R-1: use isAdmin()/isBoard() so SUPER_ADMIN is included (was excluded by hardcoded role list)
    // R-8: delete restricted to Admin only — BOARD must not be able to erase audit records
    // R-3: update hasOnly — BOARD cannot overwrite core audit fields (statementBalance, reconciledBy, etc.)
    match /reconciliations/{reconciliationId} {
      // R-5: split get/list so isAdmin() bypass works for batch admin scans (resource.data null in list)
      allow get: if isAuthenticated() && (isAdmin() || isBoard());
      allow list: if isAuthenticated() && (isAdmin() || isBoard());
      allow create: if isAuthenticated() && (isAdmin() || isBoard()) &&
        request.resource.data.keys().hasAll(['bankAccountId', 'reconciliationDate', 'reconciledBy']);
      // E6 fix: removed 'status' from BOARD hasOnly — Board must not revert completed reconciliations.
      // Status changes (e.g. in_progress → completed) require Admin.
      allow update: if isAuthenticated() && (isAdmin() ||
        (isBoard() && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'notes', 'updatedAt', 'updatedBy'
        ])));
      allow delete: if isAuthenticated() && isAdmin();
    }
    
    // Event Budgets collection
    match /eventBudgets/{budgetId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && 
                                       exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                                       get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role in ['BOARD', 'ADMIN'];
    }
    
    // Event Feedback collection
    // FIX 9: allow read was fully open — feedback contains memberId and rating visible to all;
    //        allow create had no field validation — anyone could submit on behalf of another member
    match /eventFeedback/{feedbackId} {
      // resource.data valid on get; list is board-only to protect submitter identity
      allow get: if isBoard() || isAdmin() || (isAuthenticated() && resource.data.memberId == request.auth.uid);
      allow list: if isBoard() || isAdmin();
      allow create: if isAuthenticated() &&
                      request.resource.data.memberId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['memberId', 'eventId', 'rating', 'createdAt']);
      allow update, delete: if isBoard() || isAdmin();
    }
    
    // Project Reports collection
    // FIX 23: any authenticated user could create/update/delete project reports
    match /projectReports/{reportId} {
      allow read: if isBoard() || isAdmin();
      allow create, update: if isBoard() || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Guest Registrations collection
    // FIX 22: allow update had no hasOnly whitelist — Board could overwrite any field including immutable registration data
    match /guestRegistrations/{registrationId} {
      allow read: if isBoard();
      // FIX 5: allow create: if true had no field validation — bots could write arbitrary content
      // Fields from eventsService.ts: eventId, name, email, phone, registeredAt, status, organization, notes
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'eventId', 'registeredAt'])
                    && request.resource.data.keys().hasOnly(['name', 'email', 'phone', 'eventId', 'organization', 'notes', 'registeredAt', 'status']);
      allow update: if (isBoard() || isAdmin()) &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'checkedIn', 'checkedInAt', 'notes', 'updatedAt']);
      allow delete: if isBoard();
    }
    
    // Board of Directors: boardMembers, boardTransitions (public read for guest About page)
    match /boardMembers/{docId} {
      allow read: if true;
      allow create, update, delete: if isBoard();
    }
    match /boardTransitions/{docId} {
      allow read: if true;
      allow create, update, delete: if isBoard();
    }
    // Presidential term settings (theme, tagline, description, logo) — public read for guest home page
    match /boardTermSettings/{docId} {
      allow read: if true;
      allow create, update, delete: if isBoard();
    }
    
    // Mentorship: mentorMatches, mentorshipFeedback (Mentor Matching / stats)
    match /mentorMatches/{docId} {
      // FIX 10: restrict read to isMember() — GUEST/INACTIVE should not see mentorship matches.
      // list rule is safe (no resource.data condition); get for self or board.
      allow get: if isAuthenticated() && (isBoard() || isAdmin() ||
                     resource.data.mentorId == request.auth.uid ||
                     resource.data.menteeId == request.auth.uid);
      allow list: if isActiveMember();
      allow create: if isAuthenticated() &&
                     exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                     (getUserRole() in ['BOARD', 'ADMIN'] ||
                      request.resource.data.mentorId == request.auth.uid ||
                      request.resource.data.menteeId == request.auth.uid);
      allow update, delete: if isAuthenticated() &&
                     exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                     (getUserRole() in ['BOARD', 'ADMIN'] ||
                      resource.data.mentorId == request.auth.uid ||
                      resource.data.menteeId == request.auth.uid);
    }
    match /mentorshipFeedback/{docId} {
      allow read: if isAuthenticated() && 
                     exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                     getUserRole() in ['BOARD', 'ADMIN'];
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && getUserRole() in ['BOARD', 'ADMIN'];
    }
    
    // Knowledge / Learning: training modules, learning paths, progress, certificates
    match /trainingModules/{docId} {
      allow read: if isAuthenticated() && 
                     exists(/databases/$(database)/documents/members/$(request.auth.uid)) &&
                     getUserRole() in ['MEMBER', 'BOARD', 'ADMIN'];
      allow create, update, delete: if isBoard();
    }
    match /learningPaths/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard();
    }
    // FIX 11: allow read used resource.data.memberId which is null in list queries — members could never list their own progress
    match /learningProgress/{docId} {
      // resource.data valid on get; list trusted to service-layer where(memberId == uid) filter
      allow get: if isAuthenticated() && (isBoard() || isAdmin() || resource.data.memberId == request.auth.uid);
      allow list: if isMember() || isBoard() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isBoard() || isAdmin() || (isAuthenticated() && resource.data.memberId == request.auth.uid);
    }
    // FIX 10: members could self-award certificates by setting memberId to self — create must be Admin-only
    match /certificates/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    // Inventory: maintenance schedules, inventory alerts (InventoryView)
    match /maintenance_schedules/{docId} {
      // FIX: removed getUserRole()-in-list resource.data check that blocked list queries; simplified to isMember()
      allow read: if isAuthenticated() && isMember();
      // FIX: added hasOnly whitelist on create to prevent arbitrary field injection
      allow create: if isBoard() &&
        request.resource.data.keys().hasOnly([
          'itemId','scheduledDate','nextMaintenanceDate','frequency','assignedTo','status','notes','createdAt','loId'
        ]);
      // FIX: added hasOnly on update to lock immutable fields (itemId)
      allow update: if isBoard() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'scheduledDate','nextMaintenanceDate','frequency','assignedTo','status','notes','updatedAt','completedAt','completedBy'
        ]);
      allow delete: if isBoard();
    }
    match /inventory_alerts/{docId} {
      allow read: if isAuthenticated() && isMember();
      // E9 fix: split create from update/delete to add field whitelist on create
      // FIX: added 'acknowledged' to hasOnly list
      allow create: if isBoard() &&
        request.resource.data.keys().hasAll(['itemId', 'type', 'severity', 'message']) &&
        request.resource.data.keys().hasOnly([
          'itemId', 'type', 'severity', 'message', 'threshold', 'currentValue',
          'createdAt', 'loId', 'resolved', 'acknowledged'
        ]);
      // FIX: added hasOnly whitelist to update — only acknowledgement fields writable by Board
      allow update: if isBoard() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'acknowledged','acknowledgedBy','acknowledgedAt'
        ]);
      allow delete: if isBoard();
    }
    
    // Behavioral nudging: nudge rules (Gamification — Behavioral Nudging config)
    match /nudgeRules/{docId} {
      allow read: if isMember();
      allow create, update, delete: if isBoard();
    }
    
    // Finance: payment requests — superseded by the scoped rule above (line ~244);
    // this collection is intentionally NOT re-declared here to avoid re-opening the
    // isMember()-for-everything hole (see match /paymentRequests/{requestId} above).

    // Contract System Collections
    match /contracts/{contractId} {
      // FIX 13: split read (resource.data null in list); restrict writes; hasOnly for member signing.
      allow get: if isAuthenticated() && (isAdmin() || isBoard() ||
                     resource.data.memberId == request.auth.uid);
      allow list: if isBoard() || isAdmin();
      allow create: if isMember();
      // Members may only update their own signature fields; board/admin unrestricted
      // FIX 4: restrict status values members can set — prevent self-escalation to 'active'/'completed'
      allow update: if isAdmin() || isBoard() ||
                       (isMember() &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['signerIds', 'status', 'proofUrl', 'updatedAt']) &&
                        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']) ||
                         request.resource.data.get('status', '') in ['pending_signature', 'signed', 'verifying']));
      allow delete: if isAdmin();
    }
    match /pointEscrow/{escrowId} {
      // FIX 5: split read (resource.data null in list); restrict create/update/delete.
      // Any authenticated user was able to create and modify escrow records.
      allow get: if isAuthenticated() && (isBoard() || isAdmin() ||
                     resource.data.memberId == request.auth.uid);
      allow list: if isBoard() || isAdmin();
      allow create: if isAdmin() ||
                       (isMember() &&
                        request.resource.data.memberId == request.auth.uid &&
                        request.resource.data.get('status', '') == 'pending' &&
                        request.resource.data.keys().hasOnly(['memberId', 'contractId', 'amount', 'status', 'createdAt', 'loId', 'type']));
      // Board can update status/release fields only; admin unrestricted
      allow update: if isAdmin() ||
                       (isBoard() &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status', 'releasedAt', 'releasedBy', 'contractId', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // JCI Gamification & LO Star Rating (New)
    match /incentivePrograms/{programId} {
      allow read: if isAuthenticated();
      allow write: if isBoard();
    }

    match /incentiveStandards/{standardId} {
      allow read: if isAuthenticated();
      allow write: if isBoard();
    }

    match /incentiveSubmissions/{submissionId} {
      // FIX 6: resource.data is null in list queries, so the memberId/loId conditions always failed —
      // members could never see their own submissions in list views.
      // Split: get keeps the identity check; list trusts the service-layer where(memberId == uid) filter.
      allow get: if isAuthenticated() && (isAdmin() || isBoard() ||
                     resource.data.memberId == request.auth.uid);
      allow list: if isMember();
      allow create: if isAuthenticated() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isBoard() || isAdmin();
    }

    match /loStarProgress/{progressId} {
      // FIX 14: tighten read — members see own progress via get; list safe (no resource.data condition).
      // isAdmin() covers SUPER_ADMIN which isBoard() does not always include.
      allow get: if isAdmin() || (isMember() && resource.data.memberId == request.auth.uid) || isBoard();
      allow list: if isMember();
      allow write: if isBoard() || isAdmin();
    }

    // System configuration (e.g., birthday_processor)
    match /system_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isBoard() || isAdmin();
    }

    // Radar Contributions collection
    match /RadarContributions/{contributionId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard();
    }

    // Sponsorships collection
    match /sponsorships/{sponsorshipId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard();
    }

    // System config collection (e.g. radar_mappings)
    match /system/{systemId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard();
    }
    
    // Publications (E-Newsletters): public read for guest page; Board/Admin can manage
    match /publications/{docId} {
      allow read: if true;  // Public — shows on Guest E-Newsletters page
      allow create, update, delete: if isBoard();
    }

    // Public business directory (denormalized from members — guest-readable)
    match /publicBusinessListings/{listingId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && (
        request.auth.uid == listingId || isBoard()
      );
    }
    
    // Client crash reports (web + APK) — anyone may create; Board reads; Admin deletes
    match /errorLogs/{docId} {
      allow read: if isBoard();
      allow create: if true;
      allow update: if isBoard();
      allow delete: if isAdmin();
    }

    // Guest page analytics — unauthenticated visitors increment counters; Board reads
    // FIX 16: allow update had no auth check — unauthenticated bots could inflate page view counters
    // FIX 16b: added docId format validation on create to prevent bots writing arbitrary keys
    // FIX 16c: added 10-second time throttle on update to limit bot flood writes
    match /guestPageStats/{docId} {
      allow read: if isBoard();
      // setDoc({merge:true}) triggers create on new docs, update on existing ones.
      // Both must allow unauthenticated writes (analytics only, field-locked).
      // docId must be YYYY-MM-DD_<page> format to block arbitrary key injection
      allow create: if request.resource.id.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}_(home|events|projects|about|enewsletters|directory|partnerships)$')
        && request.resource.data.keys().hasOnly(
          ['date', 'views', 'dwellSeconds', 'signupClicks', 'updatedAt']
        );
      // Time throttle: at least 10 seconds between updates to limit bot write bursts
      allow update: if request.time > resource.data.updatedAt + duration.value(10, 's')
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['views', 'dwellSeconds', 'signupClicks', 'updatedAt']);
      allow delete: if isAdmin();
    }

		// Partnership : public read for guest page; Board/Admin can manage
		match /partnerships/{docId} {
      allow read: if true;
      allow create, update, delete: if isBoard();
    }

    // ToyyibPay Categories: Board/Admin can manage; all authenticated members can read
    match /toyyibCategories/{categoryCode} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard();
    }

    // ToyyibPay Bills
    // - Board/Admin can read and write all bills
    // - Members can read and create their own bills only (for dues/event payments)
    // - Webhook writes go through Admin SDK and bypass these rules
    match /toyyibBills/{billId} {
      allow get: if isBoard() ||
                    (isAuthenticated() && resource.data.memberId == request.auth.uid);
      allow list: if isBoard() || isAdmin();
      allow create: if isBoard() ||
                       (isAuthenticated() && request.resource.data.memberId == request.auth.uid);
      allow update, delete: if isBoard();
    }

    // Finance Alerts: written by server-side (Admin SDK / webhook) for issues requiring manual review.
    // Finance roles can read and mark as resolved; only Admin SDK (no auth) writes them.
    match /finance_alerts/{alertId} {
      // FA-6: Board can read individual alerts; only Admin can list full history via SDK
      // E1 fix: added isAdmin() prefix — SUPER_ADMIN is included in isAdmin() but not in isBoard()/canAccessFinance()
      allow get: if isAdmin() || canAccessFinance();
      allow list: if isAuthenticated() && (isAdmin() || isBoard());
      // FA-1: whitelist only resolution fields; block tampering with message/transactionId
      // E5 fix: added resolved == false precondition — already-resolved alerts cannot be re-modified
      allow update: if canAccessFinance() &&
        resource.data.resolved == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['resolved', 'resolvedAt', 'resolvedBy', 'updatedAt']
        );
      allow create: if false;
      // FA-5: Admin can delete invalid/stale alerts that can't be resolved
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Audit log collection — immutable write-once records; Admin-only access for audit integrity
    // FIX: new block added; without this, auditLog had zero rules (default deny — all writes silently failed)
    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // Firestore audit log — written by firestoreLogger, read by admins only
    // FIX 17: allow create was open to any authenticated user — members could inject fake audit log entries
    match /systemLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Email delivery log — written by email-sending service functions only (via Admin SDK / service layer)
    // Board can read logs for debugging; write is Admin-only to prevent tampering
    match /emailLogs/{docId} {
      allow read: if isAdmin() || isBoard();
      allow write: if isAdmin();
    }

    // Member email dedup slots — one document per sanitised email address to enforce uniqueness
    // Members can read their own slot (to check status); only the service layer (Admin-level) writes
    match /memberEmails/{email} {
      allow read: if isAuthenticated() && canReadOrgMembers();
      // P1 Fix: require document ID to match the authenticated user's own email so no user can
      // claim another person's email slot. Bulk import uses admin context (isAdmin()) which bypasses this.
      allow create: if isAdmin() || (isAuthenticated() &&
                    !exists(/databases/$(database)/documents/memberEmails/$(email)) &&
                    request.resource.data.memberId == request.auth.uid &&
                    email == request.auth.token.email);
      allow update, delete: if isAdmin();
    }

    // Points Rules collection (server-side automation rules — different from pointRules UI config)
    // FIX 1: collection had ZERO rules — all operations silently failed with default deny
    match /pointsRules/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isBoard() || isAdmin();
    }

    // Points Rule Executions collection (execution log for automated point rule triggers)
    // FIX 1: collection had ZERO rules — execution logging always silently failed
    // FIX 2: restrict create to Admin only — any authenticated user could inject fake execution records
    match /pointsRuleExecutions/{id} {
      allow read: if isBoard() || isAdmin();
      allow create: if isAdmin() &&
        request.resource.data.keys().hasOnly([
          'ruleId','memberId','pointsAwarded','executedAt','triggerId','triggerData','loId'
        ]);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Achievement Progress collection (tracks per-member progress toward achievements)
    // FIX 14: collection had ZERO rules — unauthenticated users could read all achievement progress
    // FIX 6: tighten read — exclude GUEST and INACTIVE roles, consistent with other gamification collections
    match /achievementProgress/{id} {
      allow read: if isMember() || isBoard() || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
