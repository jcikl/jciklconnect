# Firebase Configuration (jci-lo-management-app)
# Copy this file to .env and override if needed
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=jci-lo-management-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=jci-lo-management-app
VITE_FIREBASE_STORAGE_BUCKET=jci-lo-management-app.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=212717402010
VITE_FIREBASE_APP_ID=1:212717402010:web:f8d6fd34154c8bab85ec23
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# Cloudinary Configuration (browser-safe vars only)
VITE_CLOUDINARY_CLOUD_NAME=drpa1zcmp
VITE_CLOUDINARY_UPLOAD_PRESET=jciklconnect
# Cloudinary folder prefix for member avatars (falls back to 'jciklconnect' if unset)
VITE_CLOUDINARY_MEMBER_AVATAR_ASSET_ROOT=jciklconnect
# CFG-004: CLOUDINARY_API_KEY and CLOUDINARY_API_SECRET are server-side secrets — do NOT add them
# with a VITE_ prefix here. Set them in the Netlify dashboard only (see server-side section below).

# Accessibility: set to true to run axe-core scan in dev (logs violations to console)
# VITE_A11Y_SCAN=true


# Firebase App Check — reCAPTCHA v3 site key (production only)
# Get from: Google reCAPTCHA Admin Console → register site with reCAPTCHA v3
# Then enable App Check in Firebase Console → App Check → register web app
VITE_RECAPTCHA_SITE_KEY=

# WhatsApp API (inquiry notifications via whapi.cloud)
VITE_WHAPI_TOKEN=your_whapi_token_here
VITE_WHAPI_ADMIN_PHONE=601XXXXXXXX

# Dev mock login (local dev only — never commit real values)
VITE_DEV_EMAIL=
VITE_DEV_PASSWORD=

# ---------------------------------------------------------------------------
# Server-side only (Netlify dashboard — NEVER put these in .env or .env.local)
# ---------------------------------------------------------------------------
# Firebase Admin SDK (used by Netlify Functions — no VITE_ prefix)
# FIREBASE_ADMIN_PROJECT_ID=jci-lo-management-app
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxx@jci-lo-management-app.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Cloudinary (server-side delete proxy — no VITE_ prefix)
# CLOUDINARY_CLOUD_NAME=drpa1zcmp
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ToyyibPay payment gateway
# TOYYIBPAY_SECRET_KEY=your_toyyibpay_secret_key
# TOYYIBPAY_SANDBOX=true
# TOYYIBPAY_WEBHOOK_SECRET=your_webhook_shared_secret
# TOYYIBPAY_CALLBACK_URL=https://app.jcikl.cc/api/webhooks/toyyibpay

# Cron job authentication (birthday-notifications function)
# CRON_SECRET=your_random_secret_string
